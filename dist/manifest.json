{
  "manifest_version": 3,
  "name": "Radeion Healthcare Companion",
  "version": "0.1.0",
  "description": "Secure healthcare companion extension frontend scaffold.",
  "action": {
    "default_popup": "src/ui/popup/index.html",
    "default_title": "Radeion"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "options_page": "src/ui/options/index.html",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [],
  "content_scripts": [
    {
      "js": [
        "assets/index.tsx-loader-ChXTS46G.js"
      ],
      "matches": [
        "https://example-healthcare-app.invalid/*"
      ],
      "run_at": "document_idle",
      "css": [
        "assets/renderApp-DTZHS7iA.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://example-healthcare-app.invalid/*"
      ],
      "resources": [
        "assets/*",
        "assets/renderApp-CfJNRvys.js",
        "assets/renderApp-CfJNRvys.js.map",
        "assets/createLucideIcon-SbsEQPBJ.js",
        "assets/createLucideIcon-SbsEQPBJ.js.map",
        "assets/patientTabs-0l4Ke7be.js",
        "assets/patientTabs-0l4Ke7be.js.map",
        "assets/Button-SZNNARDm.js",
        "assets/Button-SZNNARDm.js.map",
        "assets/StatusPill-C07Alrag.js",
        "assets/StatusPill-C07Alrag.js.map",
        "assets/index.tsx-4ahSD9xs.js",
        "assets/index.tsx-4ahSD9xs.js.map"
      ],
      "use_dynamic_url": false
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
